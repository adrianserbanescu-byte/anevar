{
  "manifest_version": 3,
  "name": "Import anunț → Evaluare ANEVAR",
  "version": "0.1.0",
  "description": "Trimite anunțul deschis manual către aplicația locală Evaluare ANEVAR (fără scraping automat).",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://www.imobiliare.ro/*",
    "https://www.storia.ro/*"
  ],
  "action": {
    "default_title": "Trimite anunțul în Evaluare ANEVAR"
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://www.imobiliare.ro/*", "https://www.storia.ro/*"],
      "js": ["content.js"]
    }
  ]
}
